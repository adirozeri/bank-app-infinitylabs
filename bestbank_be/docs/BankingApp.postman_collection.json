          "event": [{ "listen": "test", "script": { "exec": ["pm.test('400 not verified yet', () => { pm.response.to.have.status(400); pm.expect(pm.response.json().error).to.include('not verified yet'); });"], "type": "text/javascript" } }],
          "request": {
            "method": "POST", "header": [],
            "body": { "mode": "raw", "raw": "{\n    \"email\": \"expiry-test@test.com\",\n    \"password\": \"Secret123!\",\n    \"phone\": \"+972501234567\"\n}", "options": { "raw": { "language": "json" } } },
