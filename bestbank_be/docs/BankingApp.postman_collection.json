          "event": [{ "listen": "test", "script": { "exec": ["pm.test('400 incorrect OTP', () => { pm.response.to.have.status(400); pm.expect(pm.response.json().error).to.include('Incorrect OTP'); });"], "type": "text/javascript" } }],
          "request": {
            "method": "POST", "header": [],
            "body": { "mode": "raw", "raw": "{\n    \"email\": \"expiry-test@test.com\",\n    \"otp\": \"000000\"\n}", "options": { "raw": { "language": "json" } } },
