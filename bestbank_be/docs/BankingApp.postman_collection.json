          "request": {
            "method": "GET", "header": [],
            "url": { "raw": "http://localhost:3000/api/auth/debug-otp/expiry-test@test.com", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "auth", "debug-otp", "expiry-test@test.com"] }
