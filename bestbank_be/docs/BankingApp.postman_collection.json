      "name": "Expiry Suite 1 - Verify triggers new OTP",
      "item": [
        {
          "name": "1. Register",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('201 created', () => pm.response.to.have.status(201));"], "type": "text/javascript" } }],
          "request": {
            "method": "POST", "header": [],
            "body": { "mode": "raw", "raw": "{\n    \"email\": \"expiry-test@test.com\",\n    \"password\": \"Secret123!\",\n    \"phone\": \"+972501234567\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "http://localhost:3000/api/auth/register", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "auth", "register"] }
          },
          "response": []
        },
