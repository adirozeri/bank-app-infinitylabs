            "method": "POST", "header": [],
            "url": { "raw": "http://localhost:3000/api/auth/debug-expire-otp/expiry-test@test.com", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "auth", "debug-expire-otp", "expiry-test@test.com"] }
